rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // One progress doc per user, keyed by their (anonymous) auth uid.
    // Only that user can read or append to their own results.
    match /progress/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.results is list;

      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.results is list;

      allow delete: if false;
    }

    // Leaderboard: any signed-in (incl. anonymous) user can submit a score
    // and read the top entries. Entries are immutable once created.
    match /leaderboard/{entryId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() <= 20
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.correctCount is number
        && request.resource.data.correctCount >= 0
        && request.resource.data.totalCount is number
        && request.resource.data.totalCount >= request.resource.data.correctCount
        && request.resource.data.date is timestamp;

      allow update: if false;
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
